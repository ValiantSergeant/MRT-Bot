<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>MRT-Bot | Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --blurple: #5865F2;
            --blurple-dim: rgba(88,101,242,0.15);
            --blurple-glow: rgba(88,101,242,0.3);
            --success: #3ba55d;
            --success-dim: rgba(59,165,93,0.15);
            --danger: #ed4245;
            --danger-dim: rgba(237,66,69,0.15);
            --warning: #faa61a;
            --warning-dim: rgba(250,166,26,0.12);
            --bg: #08090d;
            --bg-2: #0e0f15;
            --surface: rgba(255,255,255,0.035);
            --surface-hover: rgba(255,255,255,0.06);
            --border: rgba(255,255,255,0.07);
            --border-strong: rgba(255,255,255,0.12);
            --text: #e8e9f0;
            --text-dim: rgba(232,233,240,0.5);
            --text-muted: rgba(232,233,240,0.3);
        }

        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--bg);
            color: var(--text);
            height: 100vh; width: 100vw;
            overflow: hidden;
            display: flex;
        }

        /* ─── SIDEBAR ─── */
        .sidebar {
            width: 68px; height: 100vh;
            background: var(--bg-2);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            align-items: center;
            padding: 16px 0;
            gap: 6px;
            flex-shrink: 0;
            transition: width 0.35s cubic-bezier(0.4,0,0.2,1);
            overflow: hidden;
            position: relative; z-index: 10;
        }
        .sidebar.expanded { width: 220px; align-items: flex-start; padding: 16px 12px; }

        .sidebar-logo {
            width: 40px; height: 40px;
            background: linear-gradient(135deg, var(--blurple), #7c5ef5);
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Space Mono', monospace; font-weight: 800; font-size: 16px; color: white;
            flex-shrink: 0;
            box-shadow: 0 4px 16px var(--blurple-glow);
            margin-bottom: 8px;
        }
        .sidebar.expanded .sidebar-logo { margin-left: 4px; }

        .sidebar-divider {
            width: 32px; height: 1px;
            background: var(--border); margin: 4px 0; flex-shrink: 0;
            transition: width 0.3s;
        }
        .sidebar.expanded .sidebar-divider { width: 100%; }

        .guild-item {
            width: 44px; height: 44px; border-radius: 50%;
            cursor: pointer;
            transition: all 0.25s cubic-bezier(0.34,1.56,0.64,1);
            position: relative;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            background: var(--surface);
            overflow: hidden;
            border: 1px solid transparent;
        }
        .sidebar.expanded .guild-item {
            width: 100%; border-radius: 10px; height: 42px;
            justify-content: flex-start; padding: 0 10px; gap: 10px;
        }
        .guild-item img { width: 100%; height: 100%; object-fit: cover; border-radius: inherit; }
        .sidebar.expanded .guild-item img { width: 28px; height: 28px; border-radius: 8px; flex-shrink: 0; }
        .guild-item:hover { background: var(--surface-hover); border-color: var(--border-strong); transform: scale(1.05); }
        .sidebar.expanded .guild-item:hover { transform: none; }
        .guild-item.active { border-color: var(--blurple); background: var(--blurple-dim); border-radius: 14px; }
        .sidebar.expanded .guild-item.active { border-radius: 10px; }
        .guild-item.active::before {
            content: ''; position: absolute; left: -12px; top: 50%; transform: translateY(-50%);
            width: 4px; height: 20px; background: var(--blurple); border-radius: 0 3px 3px 0;
        }
        .sidebar.expanded .guild-item.active::before { display: none; }
        .guild-item-name { display: none; font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text); }
        .sidebar.expanded .guild-item-name { display: block; }
        .guild-placeholder { font-family: 'Space Mono', monospace; font-weight: 800; font-size: 13px; color: var(--text-dim); }

        .sidebar-toggle {
            margin-top: auto;
            width: 40px; height: 40px; border-radius: 10px;
            background: var(--surface); border: 1px solid var(--border);
            color: var(--text-dim); cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 15px; flex-shrink: 0; transition: all 0.2s;
        }
        .sidebar.expanded .sidebar-toggle { width: 100%; justify-content: flex-end; padding-right: 10px; }
        .sidebar-toggle:hover { background: var(--surface-hover); color: var(--text); }

        /* ─── MAIN ─── */
        .main { flex: 1; height: 100vh; overflow-y: auto; overflow-x: hidden; background: var(--bg); display: flex; flex-direction: column; }
        .main::-webkit-scrollbar { width: 4px; }
        .main::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 2px; }

        /* ─── TOPBAR ─── */
        .topbar {
            position: sticky; top: 0; z-index: 5;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 28px; height: 60px;
            background: rgba(8,9,13,0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }
        .topbar-left { display: flex; align-items: center; gap: 14px; }
        .topbar-title { font-family: 'Space Mono', monospace; font-size: 15px; font-weight: 700; }
        .topbar-guild-badge {
            display: flex; align-items: center; gap: 7px;
            background: var(--blurple-dim); border: 1px solid rgba(88,101,242,0.2);
            border-radius: 8px; padding: 4px 10px 4px 7px;
            font-size: 12px; font-weight: 500; color: #a5abff;
        }
        .topbar-right { display: flex; align-items: center; gap: 8px; }
        .topbar-btn {
            height: 32px; padding: 0 12px;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 8px; color: var(--text-dim);
            font-family: 'Space Grotesk', sans-serif; font-size: 12px; font-weight: 500;
            cursor: pointer; display: flex; align-items: center; gap: 5px;
            transition: all 0.15s; text-decoration: none;
        }
        .topbar-btn:hover { background: var(--surface-hover); color: var(--text); border-color: var(--border-strong); }
        .topbar-btn.primary { background: var(--blurple-dim); border-color: rgba(88,101,242,0.3); color: #a5abff; }
        .topbar-btn.primary:hover { background: rgba(88,101,242,0.25); }

        /* ─── CONTENT ─── */
        .content { padding: 28px; flex: 1; }

        /* ─── STATS ─── */
        .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-bottom: 28px; }
        .stat-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 16px; padding: 18px 20px;
            display: flex; align-items: center; gap: 14px;
            transition: border-color 0.2s, background 0.2s;
            position: relative; overflow: hidden;
        }
        .stat-card::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(135deg, rgba(88,101,242,0.04), transparent 60%);
            pointer-events: none;
        }
        .stat-card:hover { border-color: var(--border-strong); background: var(--surface-hover); }
        .stat-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
        .stat-icon.blue { background: var(--blurple-dim); }
        .stat-icon.green { background: var(--success-dim); }
        .stat-icon.orange { background: var(--warning-dim); }
        .stat-label { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 3px; }
        .stat-value { font-family: 'Space Mono', monospace; font-size: 20px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* ─── SECTION TITLE ─── */
        .section-title {
            font-family: 'Space Mono', monospace; font-size: 12px; font-weight: 700;
            letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted);
            display: flex; align-items: center; gap: 8px; margin-bottom: 14px;
        }
        .section-title::before { content: ''; display: inline-block; width: 3px; height: 13px; background: var(--blurple); border-radius: 2px; }

        /* ─── MODULES ─── */
        .module-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px,1fr)); gap: 10px; margin-bottom: 28px; }
        .module-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 15px; transition: all 0.2s; }
        .module-card:hover { border-color: var(--border-strong); background: var(--surface-hover); }
        .module-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 11px; }
        .module-name { font-family: 'Space Mono', monospace; font-size: 13px; font-weight: 700; }
        .module-badge { font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 7px; border-radius: 6px; }
        .module-badge.on { background: var(--success-dim); color: #5dbb7c; }
        .module-badge.off { background: var(--danger-dim); color: #f07070; }
        .toggle-btn {
            width: 100%; padding: 8px; border-radius: 9px;
            border: 1px solid var(--border); background: var(--surface);
            color: var(--text-dim); font-family: 'Space Grotesk', sans-serif;
            font-size: 12px; font-weight: 500; cursor: pointer;
            transition: all 0.15s; display: flex; align-items: center; justify-content: center; gap: 5px;
        }
        .toggle-btn.on:hover { background: var(--danger-dim); border-color: rgba(237,66,69,0.3); color: #f07070; }
        .toggle-btn.off:hover { background: var(--success-dim); border-color: rgba(59,165,93,0.3); color: #5dbb7c; }

        /* ─── SEARCH ─── */
        .search-wrap { position: relative; margin-bottom: 12px; }
        .search-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); font-size: 13px; opacity: 0.3; pointer-events: none; }
        #searchInput {
            width: 100%; padding: 10px 13px 10px 38px;
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 11px; color: var(--text);
            font-family: 'Space Grotesk', sans-serif; font-size: 13px; outline: none; transition: all 0.15s;
        }
        #searchInput:focus { border-color: rgba(88,101,242,0.4); background: var(--blurple-dim); box-shadow: 0 0 0 3px rgba(88,101,242,0.08); }
        #searchInput::placeholder { color: var(--text-muted); }

        /* ─── CMD TABLE ─── */
        .cmd-table { width: 100%; border-collapse: separate; border-spacing: 0 4px; }
        .cmd-row { background: var(--surface); transition: all 0.15s; }
        .cmd-row td { padding: 10px 13px; vertical-align: middle; }
        .cmd-row td:first-child { border-radius: 10px 0 0 10px; }
        .cmd-row td:last-child { border-radius: 0 10px 10px 0; }
        .cmd-row:hover td { background: var(--surface-hover); }
        .cmd-name { font-family: 'Space Mono', monospace; font-size: 13px; font-weight: 700; color: var(--warning); }
        .cmd-cat { display: inline-block; background: var(--blurple-dim); color: #a5abff; padding: 2px 8px; border-radius: 6px; font-size: 11px; font-weight: 500; }
        .disabled-row { opacity: 0.4; }

        /* ─── BTNS ─── */
        .btn { border: none; padding: 6px 11px; border-radius: 8px; cursor: pointer; font-family: 'Space Grotesk', sans-serif; font-size: 12px; font-weight: 500; display: inline-flex; align-items: center; gap: 4px; transition: all 0.15s; white-space: nowrap; }
        .btn-gray { background: rgba(255,255,255,0.07); color: var(--text-dim); border: 1px solid var(--border); }
        .btn-gray:hover { background: rgba(255,255,255,0.12); color: var(--text); }
        .btn-danger { background: var(--danger-dim); color: #f07070; border: 1px solid rgba(237,66,69,0.2); }
        .btn-danger:hover { background: rgba(237,66,69,0.25); }
        .btn-success { background: var(--success-dim); color: #5dbb7c; border: 1px solid rgba(59,165,93,0.2); }
        .btn-success:hover { background: rgba(59,165,93,0.25); }
        .btn-blurple { background: var(--blurple-dim); color: #a5abff; border: 1px solid rgba(88,101,242,0.3); }
        .btn-blurple:hover { background: rgba(88,101,242,0.25); }
        .btn-disabled { background: rgba(255,255,255,0.03); color: var(--text-muted); cursor: not-allowed; border: 1px solid var(--border); }

        /* ─── CONSOLE ─── */
        .console-box {
            background: rgba(0,0,0,0.4); border: 1px solid var(--border);
            border-radius: 13px; padding: 14px; height: 155px;
            overflow-y: auto; font-family: 'Menlo','Consolas',monospace;
            font-size: 11px; line-height: 1.7; color: #6e7ffa; margin-top: 28px;
        }
        .console-box::-webkit-scrollbar { width: 3px; }
        .console-box::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 2px; }

        /* ─── MODALS ─── */
        .modal { display: none; position: fixed; z-index: 1000; inset: 0; background: rgba(0,0,0,0.75); backdrop-filter: blur(4px); align-items: center; justify-content: center; }
        .modal.open { display: flex; }
        .modal-box { background: #0e0f15; border: 1px solid var(--border-strong); border-radius: 18px; overflow: hidden; width: 90%; max-width: 1100px; box-shadow: 0 32px 80px rgba(0,0,0,0.7); animation: modalIn 0.25s cubic-bezier(0.34,1.56,0.64,1); }
        @keyframes modalIn { from { opacity:0; transform:scale(0.95) translateY(8px); } to { opacity:1; transform:scale(1) translateY(0); } }
        .modal-header { background: #0a0b0f; border-bottom: 1px solid var(--border); padding: 12px 18px; display: flex; align-items: center; justify-content: space-between; }
        .modal-title { font-family: 'Space Mono', monospace; font-size: 13px; font-weight: 700; color: var(--text-dim); }
        .modal-close { width: 28px; height: 28px; border-radius: 8px; background: var(--surface); border: 1px solid var(--border); color: var(--text-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 13px; transition: all 0.15s; }
        .modal-close:hover { background: var(--danger-dim); color: var(--danger); }
        .modal-footer { padding: 12px 18px; background: #0a0b0f; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 8px; }

        /* Editor */
        .editor-layout { display: flex; height: 580px; }
        .code-editor { flex: 1; background: #0d0e12; color: #abb2bf; border: none; padding: 20px; font-family: 'Menlo','Consolas',monospace; font-size: 13px; outline: none; resize: none; line-height: 1.6; }
        .ai-panel { width: 295px; background: #0a0b0f; border-left: 1px solid var(--border); display: flex; flex-direction: column; }
        .ai-panel-header { padding: 12px 14px; border-bottom: 1px solid var(--border); font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); }
        .ai-msgs { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 8px; background: #0d0e12; }
        .ai-msgs::-webkit-scrollbar { width: 2px; }
        .msg { font-size: 12px; padding: 8px 11px; border-radius: 10px; max-width: 90%; line-height: 1.5; word-wrap: break-word; }
        .msg.user { align-self: flex-end; background: var(--blurple); color: white; }
        .msg.bot { align-self: flex-start; background: rgba(255,255,255,0.05); color: var(--text-dim); border: 1px solid var(--border); }
        .ai-input-area { padding: 10px; border-top: 1px solid var(--border); }
        #aiPrompt { width: 100%; padding: 8px 10px; background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 8px; color: var(--text); font-family: 'Space Grotesk', sans-serif; font-size: 12px; resize: none; outline: none; }
        #aiPrompt:focus { border-color: rgba(88,101,242,0.4); }

        /* SQL */
        .sql-layout { display: flex; flex: 1; overflow: hidden; height: calc(85vh - 48px); }
        .sql-sidebar { width: 195px; background: #0a0b0f; border-right: 1px solid var(--border); overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 4px; }
        .sql-table-row { display: flex; align-items: center; justify-content: space-between; border-radius: 8px; overflow: hidden; }
        .sql-table-btn { flex: 1; background: none; border: none; border-radius: 8px; cursor: pointer; color: var(--text-dim); font-size: 12px; font-weight: 500; padding: 8px 10px; text-align: left; transition: all 0.15s; }
        .sql-table-btn:hover { background: var(--surface); color: var(--text); }
        .sql-main { flex: 1; display: flex; flex-direction: column; background: #0d0e12; padding: 16px; overflow: hidden; gap: 10px; }
        .sql-query-bar { display: flex; gap: 8px; align-items: center; }
        #quickSqlQuery { flex: 1; padding: 9px 12px; background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 9px; color: #4ec9b0; font-family: 'Menlo',monospace; font-size: 12px; outline: none; }
        #quickSqlQuery:focus { border-color: rgba(88,101,242,0.4); }
        #sqlResult { flex: 1; overflow: auto; }
        .pma-table { width: 100%; border-collapse: collapse; }
        .pma-table th { background: rgba(255,255,255,0.04); color: var(--text-dim); text-align: left; padding: 9px 12px; font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; border-bottom: 1px solid var(--border); }
        .pma-table td { padding: 9px 12px; font-size: 12px; color: var(--text-dim); border-bottom: 1px solid rgba(255,255,255,0.03); }
        .pma-table tr:hover td { background: var(--surface); }

        /* Small modals */
        .modal-sm { max-width: 430px; }
        .edit-field { margin-bottom: 13px; }
        .edit-label { display: block; font-size: 10px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 5px; }
        .edit-input { width: 100%; padding: 9px 12px; background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 9px; color: var(--text); font-family: 'Space Grotesk', sans-serif; font-size: 13px; outline: none; }
        .edit-input:focus { border-color: rgba(88,101,242,0.4); }
        .help-box { background: var(--blurple-dim); border: 1px solid rgba(88,101,242,0.15); border-radius: 10px; padding: 12px 14px; margin-top: 10px; font-size: 12px; color: var(--text-dim); line-height: 1.7; }

        @keyframes blink { 0%,100% { opacity:1; } 50% { opacity:0.5; } }
        .alert-blink { animation: blink 1.5s infinite; }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">
    <div class="sidebar-logo">M</div>
    <div class="sidebar-divider"></div>
    <% guilds.forEach(guild => { %>
        <div class="guild-item <%= guild.id === currentGuildId ? 'active' : '' %>"
             onclick="window.location.href='/?guild=<%= guild.id %>'"
             title="<%= guild.name %>">
            <% if (guild.icon) { %>
                <img src="<%= guild.icon %>" alt="<%= guild.name %>">
            <% } else { %>
                <div class="guild-placeholder"><%= guild.name.substring(0,2).toUpperCase() %></div>
            <% } %>
            <span class="guild-item-name"><%= guild.name %></span>
        </div>
    <% }); %>
    <button class="sidebar-toggle" id="sidebarToggleBtn" onclick="toggleSidebar()">⇤</button>
</div>

<!-- MAIN -->
<div class="main">

    <!-- Topbar -->
    <div class="topbar">
        <div class="topbar-left">
            <div class="topbar-title">Dashboard</div>
            <div class="topbar-guild-badge">⚡ <%= stats.serverName %></div>
        </div>
        <div class="topbar-right">
            <span id="aiStatus"></span>
            <button class="topbar-btn primary" onclick="openEditor('config.json', true)">🛠 Config</button>
            <button class="topbar-btn" onclick="openSqlBrowser()">📂 SQLite</button>
            <a href="/download-db" class="topbar-btn">💾 Backup</a>
            <button class="topbar-btn" onclick="toggleTheme()">🌓</button>
        </div>
    </div>

    <div class="content">

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue">📡</div>
                <div><div class="stat-label">Latence</div><div class="stat-value" id="stat-ping"><%= stats.ping %>ms</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue">🌐</div>
                <div><div class="stat-label">Serveur</div><div class="stat-value" id="stat-name"><%= stats.serverName %></div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">👥</div>
                <div><div class="stat-label">Membres</div><div class="stat-value" id="stat-users"><%= stats.users %></div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon orange">💾</div>
                <div><div class="stat-label">RAM</div><div class="stat-value" id="stat-ram"><%= stats.ram %> MB</div></div>
            </div>
        </div>

        <!-- Modules -->
        <div class="section-title">Modules</div>
        <div class="module-grid">
            <% const avMods=['Informations','Jeux','Films','Utilitaires','Modérations','Gestions','Antiraid','Contact','Paramètres','FiveM','Codex', 'Bourse', 'Ventes']; %>
            <% avMods.forEach(name => { %>
                <% const mod = modules.find(m => m.moduleName === name); const isEnabled = mod ? mod.enabled : 1; %>
                <div class="module-card">
                    <div class="module-card-top">
                        <div class="module-name"><%= name %></div>
                        <div class="module-badge <%= isEnabled ? 'on' : 'off' %>"><%= isEnabled ? 'ON' : 'OFF' %></div>
                    </div>
                    <form action="/toggle-module" method="POST">
                        <input type="hidden" name="moduleName" value="<%= name %>">
                        <input type="hidden" name="currentState" value="<%= isEnabled %>">
                        <button type="submit" class="toggle-btn <%= isEnabled ? 'on' : 'off' %>">
                            <%= isEnabled ? '⏻ Désactiver' : '⏻ Activer' %>
                        </button>
                    </form>
                </div>
            <% }); %>
        </div>

        <!-- Commands -->
        <div class="section-title">Commandes</div>
        <div class="search-wrap">
            <span class="search-icon">🔍</span>
            <input type="text" id="searchInput" onkeyup="searchCmd()" placeholder="Rechercher une commande...">
        </div>
        <table class="cmd-table" id="cmdTable">
            <tbody>
                <% allCommands.forEach(cmd => { %>
                    <%
                        const parentModule = modules.find(m => m.moduleName === cmd.category);
                        const isModuleEnabled = parentModule ? parentModule.enabled : 1;
                        const status = commandsStatus.find(s => s.commandName === cmd.name);
                        const isEnabled = status ? status.enabled : 1;
                    %>
                    <tr class="cmd-row <%= isModuleEnabled ? '' : 'disabled-row' %>">
                        <td><span class="cmd-name">+<%= cmd.name %></span></td>
                        <td><span class="cmd-cat"><%= cmd.category %></span></td>
                        <td align="right">
                            <div style="display:flex; gap:6px; justify-content:flex-end;">
                                <button class="btn btn-gray" onclick="openEditor('<%= cmd.name %>')">📝 Modifier</button>
                                <% if (isModuleEnabled) { %>
                                    <form action="/toggle-command" method="POST" style="margin:0;">
                                        <input type="hidden" name="commandName" value="<%= cmd.name %>">
                                        <input type="hidden" name="guildId" value="<%= guildId %>">
                                        <input type="hidden" name="currentState" value="<%= isEnabled %>">
                                        <button type="submit" class="btn <%= isEnabled ? 'btn-danger' : 'btn-success' %>">
                                            <%= isEnabled ? '⏻ Désactiver' : '⏻ Activer' %>
                                        </button>
                                    </form>
                                <% } else { %>
                                    <button class="btn btn-disabled" disabled>Catégorie OFF</button>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <!-- Console -->
        <div class="section-title" style="margin-top:28px;">Journal d'actions</div>
        <div id="panelLogsBox" class="console-box">En attente d'actions...</div>

    </div>
</div>


<!-- EDITOR MODAL -->
<div id="editorModal" class="modal">
    <div class="modal-box" style="max-width:1280px;">
        <div class="modal-header">
            <div class="modal-title" id="fileNameDisplay">script.js</div>
            <div class="modal-close" onclick="closeEditor()">✕</div>
        </div>
        <div class="editor-layout">
            <textarea id="codeEditor" class="code-editor" spellcheck="false"></textarea>
            <div class="ai-panel">
                <div class="ai-panel-header">✦ Assistant IA</div>
                <div id="aiMessages" class="ai-msgs"></div>
                <div class="ai-input-area">
                    <textarea id="aiPrompt" rows="3" placeholder="Poser une question..."></textarea>
                    <button id="btnSendAI" class="btn btn-blurple" style="width:100%; justify-content:center; margin-top:8px;" onclick="askAI()">Envoyer →</button>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-gray" onclick="closeEditor()">Annuler</button>
            <button class="btn" style="background:rgba(0,122,204,0.18); color:#5eb5f5; border:1px solid rgba(0,122,204,0.3);" onclick="saveCode()">💾 Enregistrer</button>
        </div>
    </div>
</div>

<!-- SQL MODAL -->
<div id="sqlModal" class="modal">
    <div class="modal-box" style="height:85vh; display:flex; flex-direction:column;">
        <div class="modal-header">
            <div class="modal-title">SQL Browser — database.sqlite3</div>
            <div class="modal-close" onclick="closeSqlBrowser()">✕</div>
        </div>
        <div class="sql-layout">
            <div id="tableList" class="sql-sidebar"></div>
            <div class="sql-main">
                <div class="sql-query-bar">
                    <input type="text" id="quickSqlQuery" placeholder="SELECT * FROM users ...">
                    <button class="btn btn-blurple" style="height:36px;" onclick="executeQuickQuery()">▶ Run</button>
                </div>
                <div style="display:flex; gap:8px;">
                    <button class="btn btn-gray" onclick="promptCreateTable()">➕ Nouvelle table</button>
                    <button class="btn btn-gray" id="emptyTableBtn" style="display:none;" onclick="openEmptyModal()">🗑 Vider</button>
                </div>
                <div id="sqlResult" style="flex:1; overflow:auto;"></div>
            </div>
        </div>
    </div>
</div>

<!-- EDIT ROW -->
<div id="editRowModal" class="modal">
    <div class="modal-box modal-sm">
        <div class="modal-header"><div class="modal-title">✏️ Éditer la ligne</div><div class="modal-close" onclick="closeEditModal()">✕</div></div>
        <div id="editFieldsContainer" style="padding:20px;"></div>
        <div class="modal-footer">
            <button class="btn btn-gray" onclick="closeEditModal()">Annuler</button>
            <button class="btn btn-success" onclick="submitEdit()">Sauvegarder</button>
        </div>
    </div>
</div>

<!-- CREATE TABLE -->
<div id="createTableModal" class="modal">
    <div class="modal-box modal-sm">
        <div class="modal-header"><div class="modal-title">➕ Créer une table</div><div class="modal-close" onclick="closeCreateModal()">✕</div></div>
        <div style="padding:20px;">
            <div class="edit-field"><label class="edit-label">Nom</label><input type="text" id="newTableName" class="edit-input" placeholder="ex: economy"></div>
            <div class="edit-field"><label class="edit-label">Colonnes (SQL)</label><input type="text" id="newTableCols" class="edit-input" placeholder="id INTEGER PRIMARY KEY, userId TEXT"></div>
            <div class="help-box">
                <strong style="color:#a5abff; display:block; margin-bottom:4px;">Guide rapide</strong>
                <code style="color:#ce9178">TEXT</code> — texte &nbsp;·&nbsp; <code style="color:#b5cea8">INTEGER</code> — nombre &nbsp;·&nbsp; <code style="color:#569cd6">PRIMARY KEY</code>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-gray" onclick="closeCreateModal()">Annuler</button>
            <button class="btn btn-blurple" onclick="submitCreateTable()">Créer</button>
        </div>
    </div>
</div>

<!-- CONFIRM -->
<div id="actionConfirmModal" class="modal">
    <div class="modal-box modal-sm">
        <div class="modal-header"><div class="modal-title">Confirmation</div><div class="modal-close" onclick="closeConfirmModal()">✕</div></div>
        <div style="padding:24px; text-align:center;">
            <p id="confirmMessage" style="color:var(--text-dim); font-size:14px;"></p>
            <div style="display:flex; justify-content:center; gap:10px; margin-top:20px;">
                <button class="btn btn-gray" onclick="closeConfirmModal()">Annuler</button>
                <button class="btn btn-danger" id="confirmBtn">Confirmer</button>
            </div>
        </div>
    </div>
</div>


<script>
    let currentEditingFile="", currentOpenedTable="", hasGeminiKey=false, aiHistory=[];
    let editRowData = {table:"",idKey:"",idVal:"",columns:[]};

    function toggleSidebar() {
        const s = document.getElementById('sidebar');
        const btn = document.getElementById('sidebarToggleBtn');
        s.classList.toggle('expanded');
        btn.innerHTML = s.classList.contains('expanded') ? '⇤' : '⇥';
    }

    async function openEditor(name, isRaw=false) {
        currentEditingFile = name; aiHistory = [];
        document.getElementById('aiMessages').innerHTML = `<div class="msg bot">Fichier <b>${name}</b> chargé.</div>`;
        document.getElementById('fileNameDisplay').innerText = name + (isRaw ? "" : ".js");
        document.getElementById('editorModal').classList.add('open');
        const res = await fetch('/get-script/' + name);
        const data = await res.json();
        document.getElementById('codeEditor').value = data.content || data.error;
    }
    function closeEditor() { document.getElementById('editorModal').classList.remove('open'); }

    async function askAI() {
        const pi = document.getElementById('aiPrompt'), message = pi.value.trim();
        const mc = document.getElementById('aiMessages'), btn = document.getElementById('btnSendAI');
        if (!message || !hasGeminiKey) return;
        mc.innerHTML += `<div class="msg user">${message}</div>`;
        pi.value = ""; mc.scrollTop = mc.scrollHeight; btn.disabled = true;
        try {
            const res = await fetch('/api/ai-chat', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({message, code: document.getElementById('codeEditor').value, fileName: currentEditingFile, history: aiHistory})});
            const data = await res.json();
            aiHistory.push({user:message, bot:data.reply});
            if (aiHistory.length > 10) aiHistory.shift();
            mc.innerHTML += `<div class="msg bot">${data.reply}</div>`;
            if (data.newCode) { document.getElementById('codeEditor').value = data.newCode; mc.innerHTML += `<div class="msg bot" style="font-style:italic;font-size:10px;">✨ Code mis à jour.</div>`; }
        } catch(e) { mc.innerHTML += `<div class="msg bot" style="color:var(--danger)">Erreur IA.</div>`; }
        btn.disabled = false; mc.scrollTop = mc.scrollHeight;
    }

    async function saveCode() {
        const res = await fetch('/save-script', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({fileName: currentEditingFile, content: document.getElementById('codeEditor').value})});
        if ((await res.json()).success) closeEditor();
    }

    async function openSqlBrowser() {
        document.getElementById('sqlModal').classList.add('open');
        const res = await fetch('/sql-tables');
        const tables = await res.json();
        const list = document.getElementById('tableList');
        list.innerHTML = '';
        tables.forEach(t => {
            const row = document.createElement('div'); row.className = 'sql-table-row';
            const b = document.createElement('button'); b.className = 'sql-table-btn'; b.innerText = t; b.onclick = () => loadTableData(t);
            const d = document.createElement('button'); d.innerHTML = '🗑'; d.style = 'background:none; border:none; color:var(--danger); cursor:pointer; padding:4px 6px;';
            d.onclick = e => { e.stopPropagation(); openConfirmModal(`Supprimer ${t} ?`, async () => { await fetch('/sql-query', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({query:`DROP TABLE ${t}`})}); openSqlBrowser(); }); };
            row.appendChild(b); row.appendChild(d); list.appendChild(row);
        });
    }
    function closeSqlBrowser() { document.getElementById('sqlModal').classList.remove('open'); }

    async function loadTableData(tableName) {
        currentOpenedTable = tableName;
        document.getElementById('emptyTableBtn').style.display = 'flex';
        const res = await fetch('/sql-query', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({query:`SELECT * FROM ${tableName} LIMIT 100`})});
        const data = await res.json();
        const rd = document.getElementById('sqlResult');
        if (data.rows && data.rows.length > 0) {
            const cols = Object.keys(data.rows[0]);
            let h = `<table class="pma-table"><thead><tr><th style="width:80px;">Actions</th>${cols.map(k=>`<th>${k}</th>`).join('')}</tr></thead><tbody>`;
            data.rows.forEach(r => {
                const rj = JSON.stringify(r).replace(/"/g,'&quot;');
                h += `<tr><td><button class="btn btn-gray" style="padding:3px 7px; margin-right:4px;" onclick="openEditModal('${tableName}', ${rj})">✏️</button><button class="btn btn-danger" style="padding:3px 7px;" onclick="openConfirmModal('Supprimer ?', async()=>{await fetch('/sql-query',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query:'DELETE FROM ${tableName} WHERE ${cols[0]} = \\'${r[cols[0]]}\\''})}); loadTableData('${tableName}');})">🗑</button></td>${Object.values(r).map(v=>`<td>${v}</td>`).join('')}</tr>`;
            });
            rd.innerHTML = h + '</tbody></table>';
        } else rd.innerHTML = `<p style="padding:20px; color:var(--text-muted); font-size:13px;">Table vide.</p>`;
    }

    async function executeQuickQuery() {
        const q = document.getElementById('quickSqlQuery').value.trim();
        if (!q) return;
        openConfirmModal("Exécuter cette requête ?", async () => {
            const res = await fetch('/sql-query', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({query:q})});
            const data = await res.json();
            if (data.error) alert(data.error);
            else { document.getElementById('quickSqlQuery').value=""; if(currentOpenedTable) loadTableData(currentOpenedTable); }
        });
    }

    function openEditModal(tableName, rowData) {
        editRowData = {table:tableName, columns:Object.keys(rowData), idKey:Object.keys(rowData)[0], idVal:rowData[Object.keys(rowData)[0]]};
        document.getElementById('editFieldsContainer').innerHTML = editRowData.columns.map(col => `<div class="edit-field"><label class="edit-label">${col}</label><input type="text" class="edit-input" id="edit_col_${col}" value="${rowData[col]}"></div>`).join('');
        document.getElementById('editRowModal').classList.add('open');
    }
    async function submitEdit() {
        const q = `UPDATE ${editRowData.table} SET ${editRowData.columns.map(c=>`${c}='${document.getElementById(`edit_col_${c}`).value}'`).join(',')} WHERE ${editRowData.idKey}='${editRowData.idVal}'`;
        await fetch('/sql-query', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({query:q})});
        closeEditModal(); loadTableData(editRowData.table);
    }

    function promptCreateTable() { document.getElementById('createTableModal').classList.add('open'); }
    async function submitCreateTable() {
        const n = document.getElementById('newTableName').value, c = document.getElementById('newTableCols').value;
        await fetch('/sql-query', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({query:`CREATE TABLE IF NOT EXISTS ${n} (${c})`})});
        closeCreateModal(); openSqlBrowser();
    }

    function openConfirmModal(msg, action) {
        document.getElementById('confirmMessage').innerText = msg;
        document.getElementById('actionConfirmModal').classList.add('open');
        document.getElementById('confirmBtn').onclick = () => { action(); closeConfirmModal(); };
    }
    function openEmptyModal() { openConfirmModal(`Vider ${currentOpenedTable} ?`, async()=>{ await fetch('/sql-query',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query:`DELETE FROM ${currentOpenedTable}`})}); loadTableData(currentOpenedTable); }); }

    function searchCmd() {
        const v = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#cmdTable tr').forEach(r => r.style.display = r.innerText.toLowerCase().includes(v) ? "" : "none");
    }

    function closeEditModal() { document.getElementById('editRowModal').classList.remove('open'); }
    function closeConfirmModal() { document.getElementById('actionConfirmModal').classList.remove('open'); }
    function closeCreateModal() { document.getElementById('createTableModal').classList.remove('open'); }

    setInterval(async () => {
        try {
            const res = await fetch('/api/stats'), data = await res.json();
            document.getElementById('stat-ping').innerText = data.ping + "ms";
            document.getElementById('stat-name').innerText = data.serverName;
            document.getElementById('stat-users').innerText = data.users;
            document.getElementById('stat-ram').innerText = data.ram + " MB";
            hasGeminiKey = data.geminiKey;
            const el = document.getElementById('aiStatus');
            if (!data.geminiKey) el.innerHTML = "<b class='alert-blink' style='color:var(--danger);font-size:11px;'>⚠️ IA OFF</b>";
            else if (data.geminiValid === false) { el.innerHTML = "<b class='alert-blink' style='color:var(--warning);font-size:11px;'>❌ Clé invalide</b>"; hasGeminiKey = false; }
            else el.innerHTML = "<span style='color:var(--success);font-size:11px;'>🟢 IA active</span>";
            const lr = await fetch('/get-panel-logs'), ld = await lr.json();
            document.getElementById('panelLogsBox').innerHTML = ld.logs.length ? ld.logs.join('<br>') : "En attente d'actions...";
        } catch(e) {}
    }, 3000);

    function toggleTheme() {
        const t = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t); localStorage.setItem('theme', t);
    }
    document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'dark');

    document.querySelectorAll('.modal').forEach(m => m.addEventListener('click', e => { if (e.target===m) m.classList.remove('open'); }));
</script>
</body>
</html>
